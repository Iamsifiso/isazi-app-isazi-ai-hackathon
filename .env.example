# Anthropic API Key for Vision Assistant
# Get your API key from: https://console.anthropic.com/
VITE_ANTHROPIC_API_KEY=your_api_key_here

# Speech-to-Text API Key
VITE_SPEECH_TO_TEXT_API_KEY=your_speech_to_text_key_here

# Google Translate API Key for translations and TTS
VITE_GOOGLE_TRANSLATE_API_KEY=your_google_translate_key_here
